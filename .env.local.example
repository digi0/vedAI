# Ved AI — environment variables
# Copy to .env.local (gitignored) and fill in. On Vercel, set these in
# Project Settings → Environment Variables.

# --- Supabase (required) -------------------------------------------------
# Public — safe in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — admin key, NEVER expose to the browser, NEVER commit
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- AI insights ---------------------------------------------------------
# Production: set ANTHROPIC_API_KEY → insights use Claude.
# Local dev: leave it unset → insights use Ollama at OLLAMA_URL.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5)
ANTHROPIC_MODEL=

# Local Ollama (only used when ANTHROPIC_API_KEY is unset)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# --- WhatsApp ingestion bot (Meta WhatsApp Cloud API) --------------------
# From the Meta App dashboard → WhatsApp.
# A string you choose; also entered in Meta's webhook config (GET handshake).
WHATSAPP_VERIFY_TOKEN=
# Meta App secret (App settings → Basic) — verifies inbound POST signatures.
WHATSAPP_APP_SECRET=
# Access token (temporary 24h test token, or a permanent System User token).
WHATSAPP_ACCESS_TOKEN=
# The phone number ID (NOT the phone number) — used to send replies.
WHATSAPP_PHONE_NUMBER_ID=

# Public — the test/display number shown in the in-app "Link WhatsApp" card.
NEXT_PUBLIC_WHATSAPP_NUMBER=
