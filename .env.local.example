# Ved AI — environment variables
# Copy to .env.local (gitignored) and fill in. On Vercel, set these in
# Project Settings → Environment Variables.

# --- Supabase (required) -------------------------------------------------
# Public — safe in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — admin key, NEVER expose to the browser, NEVER commit
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- AI insights ---------------------------------------------------------
# Production: set ANTHROPIC_API_KEY → insights use Claude.
# Local dev: leave it unset → insights use Ollama at OLLAMA_URL.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5)
ANTHROPIC_MODEL=

# Local Ollama (only used when ANTHROPIC_API_KEY is unset)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# --- WhatsApp ingestion bot (Twilio) -------------------------------------
# Server-only — from the Twilio console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional: force the exact webhook URL used for signature checks
# (set if signature validation fails behind a proxy).
TWILIO_WEBHOOK_URL=

# Public — shown in the in-app "Link WhatsApp" instructions.
# Sandbox number (e.g. +14155238886) and the sandbox join phrase.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_JOIN=
