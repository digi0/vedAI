# Ved AI — environment variables
# Copy this to .env.local and fill in the values from your Supabase project
# (Project Settings → API). .env.local is gitignored.

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — NEVER commit, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Demo phase only — until auth lands, every server write uses this user_id.
# Generate one with: node -e "console.log(crypto.randomUUID())"
DEMO_USER_ID=00000000-0000-0000-0000-000000000001
